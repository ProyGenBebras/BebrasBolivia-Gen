# Copia a .env para desarrollo local.
# Apunta al Postgres de docker-compose (docker compose up -d postgres_db).
# ?schema=bebras => requerido por multiSchema (tabla _prisma_migrations).
DATABASE_URL="postgresql://dev_user:dev_password@localhost:5432/bebras_bolivia?schema=bebras"

# Solo necesario para "prisma migrate dev" (la shadow DB se crea/destruye sola
# con dev_user, que es superusuario del contenedor; no requiere URL explicita).
# SHADOW_DATABASE_URL=""
