# Variables que docker-compose.yml sustituye en build/arranque.
# DESARROLLO LOCAL: no necesitas este archivo (el compose trae defaults).
# PRODUCCION: scripts/deploy.sh genera el .env real desde los Secrets de GitHub.
#
# Copia a .env y completa SOLO si quieres sobreescribir los defaults locales.

# --- Base de datos ---
DB_USER=usuario_admin
DB_PASSWORD=clave-robusta-aqui
DB_NAME=produccion_db

# --- URLs publicas (reemplazar IP-DEL-SERVIDOR por la IP/host real) ---
# Origen del frontend permitido por CORS en el backend
URL_CLIENTE=http://IP-DEL-SERVIDOR:3000
# URL del backend que el navegador usara (se incrusta en el build del cliente)
API_URL_PUBLICA=http://IP-DEL-SERVIDOR:4102/api/v1

# --- JWT (autenticación real) ---
JWT_SECRET=secreto-robusto-minimo-32-caracteres-aqui
JWT_EXPIRACION=15m
JWT_REFRESH_EXPIRACION=7d

# --- Semilla del primer administrador (produccion) ---
SEED_ADMIN_CORREO=admin@tu-dominio.bo
SEED_ADMIN_PASSWORD=CAMBIAR-POR-SECRETO
# En produccion: false (no sembrar datos de muestra)
SEED_DATOS_DEMO=false
