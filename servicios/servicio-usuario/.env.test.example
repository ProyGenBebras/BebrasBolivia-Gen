# Copia a .env.test para correr pruebas de integración de BD.
# Apunta a la BD de TEST del Postgres de docker-compose (separada de la de desarrollo;
# el init script scripts/db/01-crear-bd-test.sql la crea en volúmenes nuevos).
# ?schema=bebras => requerido por multiSchema (tabla _prisma_migrations).
DATABASE_URL="postgresql://dev_user:dev_password@localhost:5432/bebras_bolivia_test?schema=bebras"

# Poner en "true" para habilitar el test de conectividad real contra la BD
RUN_DB_INTEGRATION_TESTS="true"
