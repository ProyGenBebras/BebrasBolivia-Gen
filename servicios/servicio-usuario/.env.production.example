# Variables para produccion (referencia). Completar con secretos reales del entorno.

# IMPORTANTE: incluir schema=bebras en la URL. Con multiSchema, Prisma necesita
# que la tabla _prisma_migrations viva en el esquema "bebras"; sin este parametro
# "migrate deploy" falla con "migration persistence is not initialized".
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require&schema=bebras"

# Semilla del primer administrador (obligatorias en produccion; sin ellas el seed
# omite la creacion del admin). Usar un gestor de secretos, NO commitear valores.
SEED_ADMIN_CORREO="admin@tu-dominio.bo"
SEED_ADMIN_PASSWORD="CAMBIAR-POR-SECRETO"

# Dejar sin definir (o distinto de "true") en produccion: evita datos de muestra.
# SEED_DATOS_DEMO="true"
